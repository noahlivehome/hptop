    function renderGlossary(data) {
        const container = document.getElementById('glossaryContainer');
        const countContainer = document.getElementById('resultCount');
        container.innerHTML = '';
        
        countContainer.textContent = `該当件数: ${data.length}件`;

        if (data.length === 0) {
            container.innerHTML = '<p style="text-align:center; padding:30px; color:#999;">該当する用語が見つかりません。</p>';
            return;
        }

        // 50音グループおよび英数の定義
        const groups = [
            { label: 'あ行', key: 'あ' },
            { label: 'か行', key: 'か' },
            { label: 'さ行', key: 'さ' },
            { label: 'た行', key: 'た' },
            { label: 'な行', key: 'な' },
            { label: 'は行', key: 'は' },
            { label: 'ま行', key: 'ま' },
            { label: 'や行', key: 'や' },
            { label: 'ら行', key: 'ら' },
            { label: 'わ行', key: 'わ' },
            { label: '英数字・他', key: '英数' }
        ];

        groups.forEach(group => {
            const groupItems = data.filter(item => item.group === group.key);
            
            if (groupItems.length > 0) {
                const groupSection = document.createElement('div');
                groupSection.className = 'glossary-group';
                
                let html = `<h2 class="group-title">${group.label}</h2>`;
                groupItems.forEach(item => {
                    html += `
                        <div class="term-item">
                            <div class="term-title">${item.term}</div>
                            <div class="term-kana">${item.kana}</div>
                            <div class="term-desc">${item.desc}</div>
                        </div>
                    `;
                });
                groupSection.innerHTML = html;
                container.appendChild(groupSection);
            }
        });
    }

    const searchInput = document.getElementById('searchInput');
    const filterButtons = document.getElementById('filterButtons');
    let currentFilter = 'all';

    function filterData() {
        const searchText = searchInput.value.toLowerCase().trim();
        
        const filtered = glossaryData.filter(item => {
            const matchesFilter = (currentFilter === 'all' || item.group === currentFilter);
            const matchesSearch = !searchText || 
                item.term.toLowerCase().includes(searchText) ||
                item.kana.includes(searchText) ||
                item.desc.toLowerCase().includes(searchText);

            return matchesFilter && matchesSearch;
        });

        renderGlossary(filtered);
    }

    searchInput.addEventListener('input', filterData);
    
    filterButtons.addEventListener('click', (e) => {
        if (!e.target.classList.contains('filter-btn')) return;
        document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
        e.target.classList.add('active');
        currentFilter = e.target.getAttribute('data-kana');
        filterData();
    });

    // 初回実行
    renderGlossary(glossaryData);
</script>

